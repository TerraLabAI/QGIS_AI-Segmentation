FROM nvcr.io/nvidia/cuda:12.4.1-runtime-ubuntu22.04

ARG HF_TOKEN

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends software-properties-common && \
    add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update && \
    apt-get install -y --no-install-recommends python3.12 python3.12-venv python3.12-dev curl && \
    curl -sS https://bootstrap.pypa.io/get-pip.py | python3.12 && \
    ln -sf /usr/bin/python3.12 /usr/bin/python3 && \
    ln -sf /usr/bin/python3.12 /usr/bin/python && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

RUN mkdir -p /usr/local/lib/python3.12/dist-packages/assets && \
    curl -sL -o /usr/local/lib/python3.12/dist-packages/assets/bpe_simple_vocab_16e6.txt.gz \
    "https://github.com/openai/CLIP/raw/main/clip/bpe_simple_vocab_16e6.txt.gz"

RUN mkdir -p /app/checkpoints && \
    python -c "from huggingface_hub import hf_hub_download; \
    hf_hub_download('facebook/sam3', 'sam3.pt', \
    local_dir='/app/checkpoints', token='${HF_TOKEN}')"
